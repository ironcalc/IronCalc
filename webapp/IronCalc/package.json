{
  "name": "@ironcalc/workbook",
  "version": "0.7.1",
  "type": "module",
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "main": "./dist/ironcalc.js",
  "module": "./dist/ironcalc.js",
  "source": "./src/index.ts",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/ironcalc.js"
    },
    "./style.css": "./dist/ironcalc.css"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json",
    "check": "biome check ./src ./tests .storybook/ *.ts *.json && npm run lint:i18n",
    "check-write": "biome check --write ./src ./tests .storybook/ *.ts *.json",
    "lint:i18n": "node scripts/lint-i18n.js",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@ironcalc/wasm": "file:../../bindings/wasm/pkg",
    "react-colorful": "^5.6.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@storybook/react": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^16.5.8",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "i18next": "^26.3.1",
    "lucide-react": "^1.17.0",
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "react-i18next": "^16.5.8"
  },
  "files": [
    "dist"
  ]
}
