    "@vitejs/plugin-react": "^6.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "i18next": "^25.7.4",
    "lucide-react": "^0.562.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
