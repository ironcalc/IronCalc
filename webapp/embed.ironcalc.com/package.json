{
  "name": "embed.ironcalc.com",
  "private": true,
  "version": "0.7.1",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:embed": "vite build --config vite.embed.config.ts",
    "dist": "npm run build && npm run build:embed",
    "preview": "vite preview",
    "check": "biome check ./src *.html *.json",
    "check-write": "biome check --write ./src *.html *.json"
  },
  "dependencies": {
    "@ironcalc/workbook": "file:../IronCalc/",
    "lucide-react": "^0.562.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.10"
  }
}
